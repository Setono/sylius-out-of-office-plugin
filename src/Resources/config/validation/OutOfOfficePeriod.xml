<?xml version="1.0" encoding="UTF-8"?>

<constraint-mapping xmlns="http://symfony.com/schema/dic/constraint-mapping"
                    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                    xsi:schemaLocation="http://symfony.com/schema/dic/constraint-mapping https://symfony.com/schema/dic/constraint-mapping/constraint-mapping-1.0.xsd">

    <class name="Setono\SyliusOutOfOfficePlugin\Model\OutOfOfficePeriod">
        <property name="name">
            <constraint name="NotBlank">
                <option name="groups">
                    <value>setono_sylius_out_of_office</value>
                </option>
            </constraint>
        </property>

        <constraint name="Expression">
            <option name="expression">null === this.getStartsAt() or null === this.getEndsAt() or this.getEndsAt() >= this.getStartsAt()</option>
            <option name="message">setono_sylius_out_of_office.out_of_office_period.ends_at.greater_than_or_equal_starts_at</option>
            <option name="groups">
                <value>setono_sylius_out_of_office</value>
            </option>
        </constraint>

        <constraint name="Expression">
            <option name="expression">this.isShowOnTopBar() or this.isShowOnProductPage() or this.isShowAtCheckout()</option>
            <option name="message">setono_sylius_out_of_office.out_of_office_period.placements.at_least_one</option>
            <option name="groups">
                <value>setono_sylius_out_of_office</value>
            </option>
        </constraint>
    </class>

</constraint-mapping>
