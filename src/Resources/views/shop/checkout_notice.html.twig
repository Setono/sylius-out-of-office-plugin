{% set period = setono_sylius_out_of_office_active_period() %}

{% if period is not null and period.showAtCheckout and period.checkoutMessage is not empty %}
    <div class="setono-out-of-office-notice setono-out-of-office-notice--checkout"
         style="margin: 1rem 0; padding: 1rem 1.25rem; background: #fff3cd; color: #664d03; border-radius: .25rem; font-weight: 600;">
        {{ period.checkoutMessage }}
    </div>
{% endif %}
