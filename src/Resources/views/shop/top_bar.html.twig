{% set period = setono_sylius_out_of_office_active_period() %}

{% if period is not null and period.showOnTopBar and period.topBarMessage is not empty %}
    <div class="setono-out-of-office-bar"
         style="padding: .75rem 1rem; text-align: center; background: #fff3cd; color: #664d03;">
        <span class="setono-out-of-office-bar__message">{{ period.topBarMessage }}</span>
    </div>
{% endif %}
