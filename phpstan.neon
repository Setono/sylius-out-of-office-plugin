parameters:
    level: max

    paths:
        - src
        - tests

    excludePaths:
        - tests/Application/*
        - src/Migrations/*

    bootstrapFiles:
        - vendor/autoload.php

    # Symfony Configuration
    symfony:
        consoleApplicationLoader: tests/PHPStan/console_application.php

    # Doctrine Configuration
    doctrine:
        repositoryClass: Doctrine\ORM\EntityRepository
        objectManagerLoader: tests/PHPStan/object_manager.php

    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        # The channels collection is typed against the base ChannelInterface (as required by
        # ChannelsAwareInterface), while Doctrine resolves the association to the concrete Channel.
        -
            identifier: doctrine.associationType
            path: src/Model/OutOfOfficePeriod.php
        # Sylius' EntityRepository pins RepositoryInterface<ResourceInterface>, which conflicts with
        # our precise RepositoryInterface<OutOfOfficePeriodInterface> on the concrete repository.
        -
            identifier: generics.interfaceConflict
            path: src/Doctrine/ORM/OutOfOfficePeriodRepository.php
