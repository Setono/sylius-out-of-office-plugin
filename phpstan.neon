parameters:
    level: max

    paths:
        - src
        - tests

    excludePaths:
        - tests/Application/*

    bootstrapFiles:
        - vendor/autoload.php

    # Symfony Configuration
    symfony:
        consoleApplicationLoader: tests/PHPStan/console_application.php

    # Doctrine Configuration
    doctrine:
        repositoryClass: Doctrine\ORM\EntityRepository
        objectManagerLoader: tests/PHPStan/object_manager.php

    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        # The channels collection is typed against the base ChannelInterface (as required by
        # ChannelsAwareInterface), while Doctrine resolves the association to the concrete Channel.
        -
            identifier: doctrine.associationType
            path: src/Model/OutOfOfficePeriod.php
        # Lazy Twig runtime callables ([Runtime::class, 'method']) only satisfy TwigFunction's
        # `callable` parameter type from twig 3.12+; twig 2 / older twig 3 still resolve the function
        # at runtime via the runtime loader, so ignore the static-analysis-only type mismatch.
        -
            identifier: argument.type
            path: src/Twig/OutOfOfficeExtension.php
